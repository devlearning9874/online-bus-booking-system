# Copy this to .env and update values for local development
DB_USER=root
DB_PASS=secret
DB_ROOT_PASSWORD=rootpass
DB_NAME=onlinebusbooking
DB_PORT=3306
DB_HOST=localhost

# Spring Boot example for host-based microservice execution
SPRING_DATASOURCE_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}
SPRING_DATASOURCE_USERNAME=${DB_USER}
SPRING_DATASOURCE_PASSWORD=${DB_PASS}

# If your microservices run in Docker on the same network, use host 'db' instead of 'localhost'
# JDBC example inside containers: jdbc:mysql://db:3306/onlinebusbooking
